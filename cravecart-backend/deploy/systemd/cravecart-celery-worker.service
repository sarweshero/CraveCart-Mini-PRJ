[Unit]
Description=CraveCart Celery Worker
After=network.target redis.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Projects/CraveCart-Mini-PRJ/cravecart-backend
EnvironmentFile=/home/ubuntu/Projects/CraveCart-Mini-PRJ/cravecart-backend/.env
ExecStart=/home/ubuntu/.genv/bin/celery -A config worker --loglevel=info --concurrency=2
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=multi-user.target
