[Unit]
Description=CraveCart Celery Beat
After=network.target redis.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Projects/CraveCart-Mini-PRJ/cravecart-backend
EnvironmentFile=/home/ubuntu/Projects/CraveCart-Mini-PRJ/cravecart-backend/.env
ExecStart=/home/ubuntu/.genv/bin/celery -A config beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=multi-user.target
