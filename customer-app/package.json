    "@types/react-dom": "^18",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "framer-motion": "^11.2.10",
    "zustand": "^4.5.2",
    "@tanstack/react-query": "^5.40.0",
    "lucide-react": "^0.383.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "react-hot-toast": "^2.4.1",
    "date-fns": "^3.6.0",
